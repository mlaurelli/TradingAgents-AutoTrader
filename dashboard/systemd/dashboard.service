[Unit]
Description=TradingAgents Dashboard
After=network.target

[Service]
Type=exec
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/tradingagents/dashboard
Environment=PATH=/home/ubuntu/tradingagents/venv/bin
Environment=DASHBOARD_SECRET_KEY=your-super-secret-key-change-this-in-production
ExecStart=/home/ubuntu/tradingagents/venv/bin/gunicorn --config gunicorn.conf.py app:app
ExecReload=/bin/kill -s HUP $MAINPID
Restart=always
RestartSec=10
StandardOutput=append:/var/log/dashboard-access.log
StandardError=append:/var/log/dashboard-error.log

# Security
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/home/ubuntu/tradingagents/dashboard/logs

[Install]
WantedBy=multi-user.target
